{
  "name": "@402md/a2a",
  "version": "0.1.0",
  "description": "A2A protocol SDK for Node.js — discover, publish, and communicate with AI agents using the Agent-to-Agent standard",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch"
  },
  "dependencies": {
    "@402md/skillmd": "^0.1.1"
  },
  "devDependencies": {
    "tsup": "^8.5.0",
    "typescript": "^5.8.3"
  },
  "license": "MIT",
  "engines": {
    "node": ">=18"
  }
}
